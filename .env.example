# ── Supabase (Project → Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=https://DIT-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_eller_legacy_anon_key

# Server-only — n8n-writes / cron (service_role / secret key). Læg ALDRIG i klienten.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx_eller_service_role_key

# ── Anthropic (idé-AI) — console.anthropic.com ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Vercel cron-beskyttelse (valgfri men anbefalet) ──
CRON_SECRET=skriv-en-lang-tilfaeldig-streng

# ── n8n (valgfri) ──
# Live agent-status på Agenter-fanen (n8n → Settings → n8n API):
N8N_API_KEY=
# Auto-idé-loop Lag B: production-webhook-URL fra workflowet "SOMI IDEAS INTAKE".
# Uden den skrives forslag kun til Supabase (vises i dashboardet, men når ikke n8n).
N8N_IDEAS_WEBHOOK_URL=

# ── YouTube Data API (valgfri) ──
# Konkurrent-benchmark: offentlige kanal-tal. Opret en API-nøgle i Google Cloud
# (YouTube Data API v3 enabled). Uden den er benchmark-modulet tomt.
YOUTUBE_API_KEY=
# Vores egen kanal-id (UC...) — så Paper Empires kan sammenlignes i benchmark.
YT_CHANNEL_ID=
