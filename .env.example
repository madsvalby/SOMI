# ── Supabase (Project → Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=https://DIT-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx_eller_legacy_anon_key

# Server-only — n8n-writes / cron (service_role / secret key). Læg ALDRIG i klienten.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx_eller_service_role_key

# ── Anthropic (idé-AI) — console.anthropic.com ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Vercel cron-beskyttelse (valgfri men anbefalet) ──
CRON_SECRET=skriv-en-lang-tilfaeldig-streng
